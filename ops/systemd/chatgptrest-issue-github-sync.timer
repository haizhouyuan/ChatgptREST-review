# Copy to: ~/.config/systemd/user/chatgptrest-issue-github-sync.timer
# Then:
#   systemctl --user daemon-reload
#   systemctl --user enable --now chatgptrest-issue-github-sync.timer

[Unit]
Description=ChatgptREST issue-ledger to GitHub sync (every 30 minutes)

[Timer]
OnBootSec=5m
OnUnitActiveSec=30m
Persistent=true
Unit=chatgptrest-issue-github-sync.service

[Install]
WantedBy=timers.target
