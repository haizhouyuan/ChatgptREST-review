# Copy to: ~/.config/systemd/user/chatgptrest-finbot-daily-work.timer
# Then:
#   systemctl --user daemon-reload
#   systemctl --user enable --now chatgptrest-finbot-daily-work.timer
#
[Unit]
Description=ChatgptREST finbot continuous daily work sweep (every 4 hours)

[Timer]
OnBootSec=5min
OnUnitInactiveSec=4h
Persistent=true
RandomizedDelaySec=2min
Unit=chatgptrest-finbot-daily-work.service

[Install]
WantedBy=timers.target
