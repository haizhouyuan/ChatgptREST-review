# Example environment for systemd user units.
# Copy to: ~/.config/chatgptrest/chatgptrest.env
#
# Local endpoints must bypass proxy (critical).
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost

# CDP Chrome port (driver defaults to CHATGPT_CDP_URL=http://127.0.0.1:${CHROME_DEBUG_PORT}).
# If 9222 is occupied by another process (common in SSH forwarding / local debuggers), set 9226+.
# CHROME_DEBUG_PORT=9222
# Optional explicit override:
# CHATGPT_CDP_URL=http://127.0.0.1:9222
# GEMINI_CDP_URL=http://127.0.0.1:9222

# Optional outbound proxy (match your mihomo/clash port if used).
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
ALL_PROXY=socks5://127.0.0.1:7890

# Gemini region recovery (optional but recommended when Gemini/Google traffic
# rides a non-obvious mihomo group). The repair stack can switch this group and
# then restart Chrome to flush reused Google/Gemini connections.
# MIHOMO_CONTROLLER_URL=http://127.0.0.1:9090
# CHATGPTREST_GEMINI_MIHOMO_PROXY_GROUP=💻 Codex
# CHATGPTREST_GEMINI_MIHOMO_CANDIDATES=🇺🇲 美国 01,🇯🇵 日本 03
# CHATGPTREST_CODEX_AUTOFIX_ALLOW_ACTIONS=restart_chrome,restart_driver,refresh,regenerate,capture_ui,clear_blocked,switch_gemini_proxy

# Optional: allow workers to auto-submit `repair.autofix` on retryable infra/UI failures.
# This does NOT send new prompts; it may capture UI and restart Chrome/driver to recover jobs.
#
# Recommended:
# CHATGPTREST_WORKER_AUTO_CODEX_AUTOFIX=1
# CHATGPTREST_WORKER_AUTO_CODEX_AUTOFIX_MAX_RISK=medium
# CHATGPTREST_WORKER_AUTO_CODEX_AUTOFIX_MIN_INTERVAL_SECONDS=300
#
# Optional:
# CHATGPTREST_WORKER_AUTO_CODEX_AUTOFIX_APPLY_ACTIONS=1
#
# To enable the maint daemon's guarded SRE->runtime self-heal flow as well, run:
#   ops/systemd/enable_maint_self_heal.sh

# If you use an API token for ChatgptREST REST endpoints, set:
# CHATGPTREST_API_TOKEN=...
# The dashboard-only app on :8787 accepts the same bearer token(s).
#
# If you want MCP adapter to auto-start API when down:
# CHATGPTREST_MCP_AUTO_START_API=1
#
# Driver singleton lock path (recommended to keep under state/driver):
# MCP_SERVER_LOCK_FILE=/vol1/1000/projects/ChatgptREST/state/driver/chatgpt_web_mcp_server.lock
#
# MCP wait behavior (recommended for agent workflows):
# - Long waits auto-handoff to background watcher so the caller can continue other work.
# - Foreground waits are capped to prevent "single call blocks for many minutes".
# CHATGPTREST_MCP_WAIT_AUTO_BACKGROUND=1
# CHATGPTREST_MCP_WAIT_AUTO_BACKGROUND_THRESHOLD_SECONDS=90
# CHATGPTREST_MCP_WAIT_MAX_FOREGROUND_SECONDS=90
# Hard disable foreground wait loops for MCP callers (always background watch + instant return):
# CHATGPTREST_MCP_WAIT_FOREGROUND_ENABLED=0
# Optional global switch (also honored by MCP wait path):
# CHATGPTREST_DISABLE_FOREGROUND_WAIT=1
# If watcher state is missing after MCP restart, auto-resume by job_id on background_get:
# CHATGPTREST_MCP_WAIT_BACKGROUND_AUTO_RESUME=1
# CHATGPTREST_MCP_WAIT_BACKGROUND_AUTO_RESUME_TIMEOUT_SECONDS=43200

# Prompt policy guardrails (recommended defaults):
# CHATGPTREST_BLOCK_TRIVIAL_PRO_PROMPT=1
# CHATGPTREST_BLOCK_PRO_SMOKE_TEST=1

# Write-path traceability and cancel attribution (recommended for production):
# CHATGPTREST_REQUIRE_TRACE_HEADERS_FOR_WRITE=1
# CHATGPTREST_REQUIRE_CANCEL_REASON=1
# CHATGPTREST_CANCEL_REASON_MAX_CHARS=240
# Keep direct REST blocked by default; allow only explicit public clients:
# CHATGPTREST_ENFORCE_CLIENT_NAME_ALLOWLIST=chatgptrest-mcp,chatgptrestctl,openclaw-advisor
# CHATGPTREST_ENFORCE_CANCEL_CLIENT_NAME_ALLOWLIST=chatgptrestctl
# CHATGPTREST_ALLOW_FALLBACK_WHEN_MCP_DOWN=1
# CHATGPTREST_FALLBACK_CLIENT_NAME_ALLOWLIST_WHEN_MCP_DOWN=chatgptrestctl

# Gemini wait transient handling (recommended defaults):
# - During wait phase, short transport glitches are retried in-process instead of
#   immediately escalating to long cooldown.
# CHATGPTREST_GEMINI_WAIT_TRANSIENT_FAILURE_LIMIT=2
# CHATGPTREST_GEMINI_WAIT_TRANSIENT_RETRY_AFTER_SECONDS=20
# Gemini answer quality guard:
# CHATGPTREST_GEMINI_ANSWER_QUALITY_GUARD=1
# CHATGPTREST_GEMINI_SEMANTIC_CONSISTENCY_GUARD=0
# CHATGPTREST_GEMINI_ANSWER_QUALITY_RETRY_AFTER_SECONDS=180
#
# Worker wait-phase retry pacing (stable thread URL only):
# CHATGPTREST_WAIT_INFRA_RETRY_AFTER_SECONDS=20
# CHATGPTREST_WAIT_UI_RETRY_AFTER_SECONDS=12

# Qwen provider is disabled by default unless explicitly enabled.
# Keep CHATGPTREST_UI_CANARY_PROVIDERS free of qwen unless you also run the
# dedicated Qwen worker / Chrome.
# If you run the dedicated Qwen worker / Chrome, set:
# CHATGPTREST_QWEN_ENABLED=1

# OpenClaw guardian notify target (optional; choose one):
# FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...
# FEISHU_BOT_TARGET=oc_xxx_or_chat_id
# FEISHU_BOT_ACCOUNT=main
# OPENCLAW_CMD=openclaw
# Client issue auto-mitigate sweep (guardian):
# CHATGPTREST_CLIENT_ISSUE_AUTOCLOSE_HOURS=72
# CHATGPTREST_CLIENT_ISSUE_AUTOCLOSE_MAX=50
# CHATGPTREST_CLIENT_ISSUE_AUTOCLOSE_SOURCE=worker_auto
# CHATGPTREST_CLIENT_ISSUE_AUTOCLOSE_STATUSES=open,in_progress
# CHATGPTREST_CLIENT_ISSUE_AUTOCLOSE_ACTOR=openclaw_guardian
# CHATGPTREST_CLIENT_ISSUE_CLOSE_AFTER_SUCCESSES=3
# CHATGPTREST_CLIENT_ISSUE_CLOSE_MAX=20
# Issue report guard (default on): block non-worker_auto open-report when referenced job(s) are already completed.
# CHATGPTREST_ISSUE_REPORT_REQUIRE_ACTIVE_JOB=1
# Issue ledger -> GitHub sync (optional; requires gh auth with repo scope):
# CHATGPTREST_GITHUB_ISSUE_SYNC_ENABLED=1
# CHATGPTREST_GITHUB_ISSUE_SYNC_REPO=haizhouyuan/ChatgptREST
# CHATGPTREST_GITHUB_ISSUE_SYNC_SOURCE=worker_auto
# CHATGPTREST_GITHUB_ISSUE_SYNC_OPEN_LIMIT=200
# CHATGPTREST_GITHUB_ISSUE_SYNC_CLOSED_LIMIT=100
# CHATGPTREST_GITHUB_ISSUE_SYNC_CLOSED_LOOKBACK_HOURS=168
#
# Optional: OpenClaw issue-dev controller lane command templates.
# The controller expands placeholders like {worktree_q}, {implementer_prompt_q},
# {implementer_output_q}, {reviewer_prompt_q}, {reviewer_output_q},
# {implementer_schema_q}, {reviewer_schema_q}, and {pull_request_url_q}.
# CHATGPTREST_DEV_LOOP_IMPLEMENTER_CMD_TEMPLATE=cd {worktree_q} && codex exec --skip-git-repo-check --cd {worktree_q} --sandbox workspace-write --output-schema {implementer_schema_q} -o {implementer_output_q} - < {implementer_prompt_q}
# CHATGPTREST_DEV_LOOP_REVIEWER_CMD_TEMPLATE=claudeminmax -p "$(cat {reviewer_prompt_q})" --output-format json > {reviewer_output_q}
#
# Optional: hcom/OpenClaw remote roles for the same controller loop.
# Leave command templates empty if you want the controller to dispatch by hcom.
# The remote role must share the same filesystem/worktree and write the JSON result
# to the provided output_tmp_path first, then atomically rename it to output_path.
# Targets are exact matches unless you use an explicit wildcard such as @impl-*.
# CHATGPTREST_DEV_LOOP_IMPLEMENTER_HCOM_TARGET=@impl-1
# CHATGPTREST_DEV_LOOP_REVIEWER_HCOM_TARGET=@review-1
# CHATGPTREST_DEV_LOOP_HCOM_DIR=/abs/path/to/hcom_dir
# CHATGPTREST_DEV_LOOP_HCOM_SENDER=issue-dev-controller
# CHATGPTREST_DEV_LOOP_HCOM_POLL_SECONDS=2.0
# CHATGPTREST_DEV_LOOP_IMPLEMENTER_TIMEOUT_SECONDS=1800
# CHATGPTREST_DEV_LOOP_REVIEWER_TIMEOUT_SECONDS=1800

# Periodic monitor (chatgptrest-monitor-12h.timer):
# CHATGPTREST_MONITOR_12H_SECONDS=43200
# CHATGPTREST_MONITOR_12H_DIR=/vol1/1000/projects/ChatgptREST/artifacts/monitor/periodic
# CHATGPTREST_PYTHON_BIN=/vol1/1000/projects/ChatgptREST/.venv/bin/python

# Viewer watchdog (chatgptrest-viewer-watchdog.timer):
# CHATGPTREST_VIEWER_WATCHDOG_STATUS_TIMEOUT_SECONDS=15
# CHATGPTREST_VIEWER_WATCHDOG_SLEEP_AFTER_RESTART_SECONDS=1
# CHATGPTREST_VIEWER_WATCHDOG_MAX_HEAL_ATTEMPTS=2
# CHATGPTREST_VIEWER_WATCHDOG_GPU_EXIT15_THRESHOLD=3
# CHATGPTREST_VIEWER_WATCHDOG_CHROME_LOG_LINES=200

# Maint daemon knobs (optional)
# CHATGPTREST_INCIDENT_AUTO_RESOLVE_AFTER_HOURS=72
# CHATGPTREST_ENABLE_ISSUES_REGISTRY_WATCH=1
# CHATGPTREST_ISSUES_REGISTRY_PATH=docs/issues_registry.yaml
#
# Global Codex memory (optional, default on)
# CHATGPTREST_ENABLE_CODEX_GLOBAL_MEMORY=1
# CHATGPTREST_CODEX_GLOBAL_MEMORY_DIGEST_MAX_RECORDS=200
# CHATGPTREST_CODEX_GLOBAL_MEMORY_PROMPT_MAX_CHARS=60000
# CHATGPTREST_CODEX_GLOBAL_MEMORY_MAX_BYTES=0
# Optional: inject maintagent machine/workspace bootstrap memory from /vol1/maint.
# If omitted, ChatgptREST auto-discovers the newest /vol1/maint/exports/maintagent_memory_packet_*.json.
# CHATGPTREST_MAINT_BOOTSTRAP_MEMORY_PACKET=/vol1/maint/exports/maintagent_memory_packet_2026-03-15.json
# CHATGPTREST_MAINT_BOOTSTRAP_MEMORY_STALE_HOURS=168
#
# If systemd PATH doesn't include codex, pin an explicit binary:
# CHATGPTREST_CODEX_BIN=/abs/path/to/codex

# Dashboard Control Plane (read-only operator UI on port 8787)
# CHATGPTREST_DASHBOARD_HOST=127.0.0.1
# CHATGPTREST_DASHBOARD_PORT=8787
# CHATGPTREST_DASHBOARD_DB_PATH=/vol1/1000/projects/ChatgptREST/state/dashboard_control_plane.sqlite3
# CHATGPTREST_DASHBOARD_REFRESH_INTERVAL_SECONDS=15
# CHATGPTREST_DASHBOARD_BOOTSTRAP_ON_READ=1
