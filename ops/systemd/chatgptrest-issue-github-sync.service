# Copy to: ~/.config/systemd/user/chatgptrest-issue-github-sync.service
# Then:
#   systemctl --user daemon-reload
#   systemctl --user enable --now chatgptrest-issue-github-sync.timer

[Unit]
Description=ChatgptREST issue-ledger to GitHub sync
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__CHATGPTREST_ROOT__
EnvironmentFile=-%h/.config/chatgptrest/chatgptrest.env
ExecStart=__CHATGPTREST_ROOT__/.venv/bin/python ops/sync_issue_ledger_to_github.py

