# Copy to: ~/.config/systemd/user/chatgptrest-mihomo-delay.timer
# Then:
#   systemctl --user daemon-reload
#   systemctl --user enable --now chatgptrest-mihomo-delay.timer
#
[Unit]
Description=ChatgptREST mihomo proxy delay snapshot (every 5 minutes)

[Timer]
OnCalendar=*-*-* *:0/5:00
Persistent=true
RandomizedDelaySec=30

[Install]
WantedBy=timers.target

