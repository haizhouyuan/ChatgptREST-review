      },
      "openmind-graph": {
        "enabled": true,
        "config": {
          "endpoint": {
            "baseUrl": "http://127.0.0.1:18711",
            "apiKey": "<redacted>"
          },
          "defaultRepo": "ChatgptREST",
          "defaultScopes": [
            "personal_graph",
            "repo_graph"
          ]
        }
      },
      "openmind-memory": {
        "enabled": true,
        "config": {
          "endpoint": {
            "baseUrl": "http://127.0.0.1:18711",
