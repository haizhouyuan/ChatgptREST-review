          "domainTags": [
            "openclaw",
            "openmind"
          ],
          "cacheTtlSeconds": 180,
          "tokenBudget": "<redacted>",
          "repo": "ChatgptREST"
        }
      },
      "openmind-telemetry": {
        "enabled": true,
        "config": {
          "endpoint": {
            "baseUrl": "http://127.0.0.1:18711",
            "apiKey": "<redacted>"
          },
          "enabled": true,
          "ignoreOwnTools": true
