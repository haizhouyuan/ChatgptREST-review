{
  "models": {
    "providers": {}
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": [
      "127.0.0.1/32",
      "::1/128"
    ],
    "controlUi": {
      "allowInsecureAuth": false
    },
    "auth": {
      "mode": "token",
      "allowTailscale": false,
      "token": "<redacted>"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "session": {
    "agentToAgent": {
      "maxPingPongTurns": 0
