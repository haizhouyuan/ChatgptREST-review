        "model": "text-embedding-v2"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "thinkingDefault": "high",
      "maxConcurrent": 4,
      "sandbox": {
        "mode": "non-main",
        "scope": "session",
        "workspaceAccess": "none",
        "sessionToolsVisibility": "all"
      },
      "subagents": {
        "maxConcurrent": 6,
        "thinking": "high",
        "runTimeoutSeconds": 1200
      }
    },
    "list": [
      {
        "id": "main",
        "workspace": "/vol1/1000/openclaw-workspaces/main",
        "model": "openai-codex/gpt-5.4",
        "tools": {
          "profile": "coding",
          "alsoAllow": [
