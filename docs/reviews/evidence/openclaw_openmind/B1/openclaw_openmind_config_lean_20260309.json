        "name": "Main",
        "default": true,
        "skills": [
          "chatgptrest-call"
        ],
        "heartbeat": {
          "every": "30m",
          "target": "none",
          "lightContext": true,
          "activeHours": {
            "start": "08:00",
            "end": "24:00",
            "timezone": "Asia/Shanghai"
          }
        }
      }
    ]
