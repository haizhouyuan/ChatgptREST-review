  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": [
          "google-gemini-cli/gemini-2.5-pro"
        ]
      },
      "models": {
        "openai-codex/gpt-5.4": {},
        "google-gemini-cli/gemini-2.5-pro": {},
        "google-antigravity/claude-opus-4-6-thinking": {}
      },
      "userTimezone": "Asia/Shanghai",
