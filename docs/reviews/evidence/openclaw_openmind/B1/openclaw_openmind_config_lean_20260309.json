    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "7d",
      "maxEntries": 500,
      "rotateBytes": "10mb"
    }
  },
  "tools": {
    "profile": "coding",
    "agentToAgent": {
      "enabled": false,
      "allow": []
    },
    "sessions": {
      "visibility": "all"
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "on-miss",
      "timeoutSec": 1200,
      "notifyOnExit": true
    }
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": [
      "codex",
      "gemini",
      "claude"
    ]
  },
  "skills": {
    "allowBundled": [],
