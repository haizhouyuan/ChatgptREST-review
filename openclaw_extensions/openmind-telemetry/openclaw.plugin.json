{
  "id": "openmind-telemetry",
  "name": "OpenMind Telemetry",
  "description": "Bridge OpenClaw execution telemetry into OpenMind EvoMap.",
  "version": "2026.3.8",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "endpoint": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": { "type": "string" },
          "apiKey": { "type": "string" },
          "timeoutMs": { "type": "number", "minimum": 1000, "maximum": 300000 }
        },
        "required": ["baseUrl"]
      },
      "enabled": { "type": "boolean" },
      "batchSize": { "type": "number", "minimum": 1, "maximum": 100 },
      "flushIntervalMs": { "type": "number", "minimum": 1000, "maximum": 600000 },
      "ignoreOwnTools": { "type": "boolean" },
      "defaultRoleId": { "type": "string" },
      "repoName": { "type": "string" },
      "repoPath": { "type": "string" },
      "taskRefPrefix": { "type": "string" },
      "defaultProvider": { "type": "string" },
      "defaultModel": { "type": "string" },
      "executorKind": { "type": "string" }
    },
    "required": ["endpoint"]
  }
}
